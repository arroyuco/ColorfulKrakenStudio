@page "/account"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using ColorfulKrakenStudio.Services
@using ColorfulKrakenStudio.Models
@inject PurchaseService PurchaseService
@inject UserManager<Customer> UserManager
@inject NavigationManager Navigation
@inject CurrentUserService CurrentUser
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<Account> _logger

<PageTitle>My account — ColorfulKrakenStudio</PageTitle>

@if (isLoading)
{
    <p class="loading">Loading...</p>
}
else if (!isAuthenticated)
{
    <p>You must be logged in to view this page.</p>
}
else
{
    <div class="account-container">
        <h1>My account</h1>

        <!-- SECCIÓN 1: Datos personales -->
        <section class="account-section">
            <h2>Personal details</h2>
            @if (profileSaved)
            {
                <div class="alert-success">Changes saved successfully.</div>
            }
            @if (!string.IsNullOrEmpty(profileError))
            {
                <div class="auth-error">@profileError</div>
            }
            <div class="account-form">
                <div class="form-row">
                    <div class="form-group">
                        <label>First name</label>
                        <input type="text" @bind="firstName" />
                    </div>
                    <div class="form-group">
                        <label>Last name</label>
                        <input type="text" @bind="lastName" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" @bind="email" />
                </div>
                <button type="button" class="btn-save" @onclick="SaveProfile" disabled="@isSavingProfile">
                    @(isSavingProfile ? "Saving..." : "Save changes")
                </button>
            </div>
        </section>

        <!-- SECCIÓN 2: Cambiar contraseña -->
        <section class="account-section">
            <h2>Change password</h2>
            @if (passwordSaved)
            {
                <div class="alert-success">Password changed successfully.</div>
            }
            @if (!string.IsNullOrEmpty(passwordError))
            {
                <div class="auth-error">@passwordError</div>
            }
            <div class="account-form">
                <div class="form-group">
                    <label>Current password</label>
                    <input type="password" @bind="currentPassword" />
                </div>
                <div class="form-group">
                    <label>New password</label>
                    <input type="password" @bind="newPassword" />
                </div>
                <div class="form-group">
                    <label>Confirm new password</label>
                    <input type="password" @bind="confirmPassword" />
                </div>
                <button type="button" class="btn-save" @onclick="ChangePassword" disabled="@isSavingPassword">
                    @(isSavingPassword ? "Saving..." : "Change password")
                </button>
            </div>
        </section>

        <!-- SECCIÓN 3: Tutoriales comprados -->
        <section class="account-section">
            <h2>My tutorials</h2>
            @if (!purchasedTutorials.Any())
            {
                <p class="empty-state">You haven't purchased any tutorials yet. <a href="/tutorials">Browse tutorials</a></p>
            }
            else
            {
                <div class="purchased-grid">
                    @foreach (var tutorial in purchasedTutorials)
                    {
                        <div class="purchased-card">
                            <div class="purchased-thumb thumb-@tutorial.Id"></div>
                            <div class="purchased-body">
                                <h3>@tutorial.Title</h3>
                                <p>@tutorial.Author · @tutorial.Duration min</p>
                                <a href="/tutorials/@tutorial.Id" class="btn-watch">Watch now</a>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>

        <!-- SECCIÓN 4: Historial de pagos -->
        <section class="account-section">
            <h2>Payment history</h2>
            @if (!purchaseHistory.Any())
            {
                <p class="empty-state">No purchases yet.</p>
            }
            else
            {
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>Tutorial</th>
                            <th>Date</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var purchase in purchaseHistory)
                        {
                            <tr>
                                <td>@purchase.Tutorial.Title</td>
                                <td>@purchase.PurchasedAt.ToString("dd MMM yyyy")</td>
                                <td>€@purchase.AmountPaid</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private string customerId = string.Empty;

    private string firstName = string.Empty;
    private string lastName = string.Empty;
    private string email = string.Empty;

    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;

    private bool isSavingProfile = false;
    private bool isSavingPassword = false;
    private bool profileSaved = false;
    private bool passwordSaved = false;
    private string profileError = string.Empty;
    private string passwordError = string.Empty;

    private List<ColorfulKrakenStudio.Models.Tutorial> purchasedTutorials = new();
    private List<Purchase> purchaseHistory = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isAuthenticated = user.Identity?.IsAuthenticated ?? false;

        if (!isAuthenticated)
        {
            isLoading = false;
            return;
        }
        await CurrentUser.GetCustomerAsync(user);

        customerId = CurrentUser.Id;
        firstName = CurrentUser.FirstName;
        lastName = CurrentUser.LastName;
        email = CurrentUser.Email;

        purchasedTutorials = await PurchaseService.GetPurchasedTutorialsAsync(customerId);
        purchaseHistory = await PurchaseService.GetPurchaseHistoryAsync(customerId);

        isLoading = false;
    }

    private async Task SaveProfile()
    {
        isSavingProfile = true;
        profileSaved = false;
        profileError = string.Empty;

        var customer = await UserManager.FindByIdAsync(customerId);
        if (customer == null) return;

        customer.FirstName = firstName;
        customer.LastName = lastName;
        customer.Email = email;
        customer.UserName = email;

        var result = await UserManager.UpdateAsync(customer);

        if (result.Succeeded)
        {
            CurrentUser.Invalidate();
            profileSaved = true;
        }
        else
            profileError = result.Errors.First().Description;

        isSavingProfile = false;
    }

    private async Task ChangePassword()
    {
        isSavingPassword = true;
        passwordSaved = false;
        passwordError = string.Empty;

        if (newPassword != confirmPassword)
        {
            passwordError = "Passwords do not match.";
            isSavingPassword = false;
            return;
        }

        var customer = await UserManager.FindByIdAsync(customerId);
        if (customer == null) return;

        var result = await UserManager.ChangePasswordAsync(customer, currentPassword, newPassword);

        if (result.Succeeded)
        {
            passwordSaved = true;
            currentPassword = string.Empty;
            newPassword = string.Empty;
            confirmPassword = string.Empty;
        }
        else
        {
            passwordError = result.Errors.First().Description;
        }

        isSavingPassword = false;
    }
}