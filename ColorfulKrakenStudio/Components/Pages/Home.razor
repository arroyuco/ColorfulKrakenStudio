@page "/"

@using ColorfulKrakenStudio.Services
@using ColorfulKrakenStudio.Models
@using Microsoft.AspNetCore.Identity
@inject PurchaseService PurchaseService
@inject UserManager<Customer> UserManager
@inject TutorialService TutorialService
@inject CurrentUserService CurrentUser

<PageTitle>ColorfulKrakenStudio — Miniature Painting Tutorials</PageTitle>

<section class="hero">
    <h1>Learn to paint miniatures<br />quickly and with great results</h1>
    <p>Premium tutorials created by some of the world's best painters.</p>
    <div class="hero-buttons">
        <a href="/tutorials" class="btn-primary">Browse tutorials</a>
        <AuthorizeView>
            <NotAuthorized>
                <a href="/register" class="btn-secondary">Sign up for free</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</section>

<section class="section">
    <h2>Featured tutorials</h2>
    <div class="card-grid">
        @foreach (var tutorial in featuredTutorials)
        {
            <div class="tutorial-card">
                <div class="card-badge @(tutorial.IsFree ? "badge-free" : "badge-pro")">
                    @(tutorial.IsFree ? "Free" : "Pro")
                </div>
                <h3>@tutorial.Title</h3>
                <p>@tutorial.Author · @tutorial.Duration min</p>
            </div>
        }
    </div>
</section>

<section class="section">
    <h2>Plans</h2>
    <div class="plans-grid">
        <div class="plan">
            <h3>Free</h3>
            <p class="price">€0 <span>/month</span></p>
            <ul>
                <li>1 free tutorial</li>
                <li>Public articles</li>
            </ul>
            <a href="/register" class="btn-secondary">Get started</a>
        </div>
        <div class="plan plan-featured">
            <span class="plan-badge">Most popular</span>
            <h3>Pro</h3>
            <p class="price">€9 <span>/month</span></p>
            <ul>
                <li>All tutorials</li>
                <li>Early access</li>
            </ul>
            <a href="/plans" class="btn-primary">Choose Pro</a>
        </div>
        <div class="plan">
            <h3>VIP</h3>
            <p class="price">€19 <span>/month</span></p>
            <ul>
                <li>Everything in Pro</li>
                <li>PDFs and resources</li>
            </ul>
            <a href="/plans" class="btn-secondary">Choose VIP</a>
        </div>
    </div>
</section>

@code {
    private List<ColorfulKrakenStudio.Models.Tutorial> featuredTutorials = new();

    protected override async Task OnInitializedAsync()
    {
        var all = await TutorialService.GetAllAsync();
        featuredTutorials = all.Take(3).ToList();
    }
}