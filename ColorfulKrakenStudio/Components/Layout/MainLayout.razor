@inherits LayoutComponentBase
@using Microsoft.Extensions.Localization
@using ColorfulKrakenStudio.Resources
@inject IStringLocalizer<SharedResources> L

<div class="page">
    <header class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-logo">ColorfulKrakenStudio</a>
            <nav class="navbar-links">
                <a href="/tutorials">@L["Nav_Tutorials"]</a>
                <a href="/articles">@L["Nav_Articles"]</a>
                <a href="/plans">@L["Nav_Plans"]</a>
            </nav>

            <div class="navbar-auth">
                <AuthorizeView Context="authContext">
                    <Authorized>
                        <span class="navbar-user">Hi, @authContext.User.Identity?.Name</span>
                        <a href="/account">@L["Nav_MyAccount"]</a>
                        <form action="/auth/logout" method="post" style="display:inline">
                            <button type="submit" class="btn-logout">@L["Nav_Logout"]</button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/register" class="btn-register">@L["Nav_SignUp"]</a>
                        <a href="/login" class="btn-login">@L["Nav_Login"]</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
            <div class="lang-selector">
                <form action="/culture/set" method="post">
                    <input type="hidden" name="redirectUri" value="/" />
                    <button type="submit" name="culture" value="en" class="lang-btn">EN</button>
                    <button type="submit" name="culture" value="es" class="lang-btn">ES</button>
                </form>
            </div>
        </div>
    </header>

    <main class="content">
        @Body
    </main>
</div>